# QuantAlpha HFT System - Environment Variables Example
# Copy this file to .env and adjust values for your local environment

# ── Backend Configuration ─────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=debug
JWT_SECRET=quantalpha-secret-key-change-in-production
JWT_EXPIRE_HOUR=24

# ── Database Configuration ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=quantalpha
DB_SSLMODE=disable

# ── Redis Configuration ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── MinIO Configuration ───────────────────────────────────────
# (Optional, if using object storage for alphas/logs)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=quant-alpha
MINIO_USE_SSL=false

# ── Worker Configuration ──────────────────────────────────────
DATA_DIR=./data
REDIS_URL=redis://localhost:6379/0
WORKER_LOG_LEVEL=INFO

# ── Frontend Configuration ────────────────────────────────────
# Note: These values are used to configure the frontend at build/runtime.
# For local dev without containers, use http://localhost:8080
# For Docker Compose, the browser still accesses via localhost:8080
API_URL=http://localhost:8080
